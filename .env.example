# =============================================================================
# OpenEnv Education Track — Environment Variables
# =============================================================================
# 1. Copy this file:  cp .env.example .env
# 2. Fill in secrets: HF_TOKEN is required. WANDB_API_KEY is optional.
# 3. Tune the rest to your hardware. Defaults work for a single GPU machine.
#
# NEVER commit .env to version control.
# =============================================================================

# ── Secrets (required) ────────────────────────────────────────────────────────
# For OpenAI-compatible APIs (Groq, Together, OpenRouter, Qwen, etc.):
OPENAI_API_KEY=
OPENAI_API_BASE=
MODEL_NAME=qwen/qwen3-32b

# Get your HuggingFace token at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_REPLACE_WITH_YOUR_TOKEN

# Weights & Biases for training curves (leave blank to skip)
WANDB_API_KEY=

# ── Training ──────────────────────────────────────────────────────────────────
# Base model to fine-tune (must be accessible with your HF_TOKEN)
MODEL_NAME=Qwen/Qwen3-1.7B

# Set to true to push each checkpoint to HuggingFace Hub after training
PUSH_TO_HUB=false

# CUDA version for trainer image — must match your driver
# Check with: nvidia-smi | grep "CUDA Version"
CUDA_VERSION=12.4.1

# ── Easy env (Adaptive Quiz Tutor) ───────────────────────────────────────────
EASY_PORT=8001
EASY_WORKERS=4
EASY_MAX_ENVS=100
SHAPED_REWARD=true       # ZPD bonus reward shaping (recommended: true)

# ── Medium env (Essay Feedback Coach) ────────────────────────────────────────
MEDIUM_PORT=8002
MEDIUM_WORKERS=4
MEDIUM_MAX_ENVS=100

# ── Hard env (Dropout Risk Intervention) ─────────────────────────────────────
HARD_PORT=8003
HARD_WORKERS=2           # Lower: each episode holds 14-week session state
HARD_MAX_ENVS=50
SEMESTER_WEEKS=14        # Change to 7 for faster dev iterations

# ── Shared ────────────────────────────────────────────────────────────────────
LOG_LEVEL=info           # debug | info | warning | error

# ── Optional dashboard ────────────────────────────────────────────────────────
DASHBOARD_PORT=3000
